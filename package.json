{
  "name": "@qredex/agent",
  "version": "1.1.1",
  "description": "Lightweight browser agent for Qredex intent capture and locking",
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "main": "./dist/qredex-agent.es.js",
  "module": "./dist/qredex-agent.es.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/qredex-agent.iife.min.js",
  "jsdelivr": "./dist/qredex-agent.iife.min.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/qredex-agent.es.js",
      "default": "./dist/qredex-agent.es.js"
    },
    "./qredex-agent.iife.js": "./dist/qredex-agent.iife.js",
    "./qredex-agent.iife.min.js": "./dist/qredex-agent.iife.min.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:agent && npm run build:wrappers",
    "build:agent": "tsc && vite build && vite build --config vite.iife.config.ts && node scripts/copy-iife-min.js production",
    "build:dev": "tsc && vite build --mode development && vite build --config vite.iife.config.ts --mode development && node scripts/copy-iife-min.js development",
    "build:cdn:dev": "QREDEX_AGENT_LOCK_ENDPOINT=http://127.0.0.1:8080/api/v1/agent/intents/lock npm run build:dev",
    "build:stage": "tsc && vite build --mode staging && vite build --config vite.iife.config.ts --mode staging && node scripts/copy-iife-min.js staging",
    "build:wrappers": "npm run build --workspaces --if-present --include-workspace-root=false",
    "example": "node scripts/run-example.mjs",
    "example:serve": "npm run build:dev && vite --config vite.examples.config.ts --host 127.0.0.1 --port 3000",
    "preview": "vite preview",
    "lint": "eslint src packages",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.html\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"examples/**/*.html\"",
    "release:check": "npm run test && npm run build && node scripts/verify-release.mjs",
    "release:version": "node scripts/set-release-version.mjs",
    "release:cdn": "npm run build && node scripts/prepare-cdn-release.mjs",
    "release:cdn:upload": "node scripts/upload-cdn-release.mjs",
    "release:cdn:verify": "node scripts/verify-cdn-history.mjs",
    "release:cdn:backfill": "node scripts/backfill-cdn-history.mjs",
    "release:cdn:dev": "npm run build:cdn:dev && node scripts/prepare-cdn-release.mjs dev",
    "release:cdn:dev:upload": "node scripts/upload-cdn-release.mjs dev",
    "release:cdn:staging": "npm run build:stage && node scripts/prepare-cdn-release.mjs staging",
    "release:cdn:staging:upload": "node scripts/upload-cdn-release.mjs staging",
    "publish:npm:dry-run": "npm run release:check && node scripts/publish-packages.mjs --dry-run",
    "publish:npm": "npm run release:check && node scripts/publish-packages.mjs",
    "test": "vitest run",
    "test:browser": "npm run build:dev && playwright test",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:bun": "bun test",
    "link": "bun link",
    "unlink": "bun unlink"
  },
  "keywords": [
    "qredex",
    "browser-agent",
    "intent",
    "ecommerce"
  ],
  "author": "Qredex",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qredex/qredex-agent.git"
  },
  "homepage": "https://github.com/Qredex/qredex-agent#readme",
  "bugs": {
    "url": "https://github.com/Qredex/qredex-agent/issues"
  },
  "devDependencies": {
    "@angular/common": "^20.3.2",
    "@angular/compiler": "^20.3.2",
    "@angular/core": "^20.3.2",
    "@angular/platform-browser": "^20.3.2",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/ui": "^1.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "happy-dom": "^13.3.8",
    "prettier": "^3.2.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.0",
    "rxjs": "^7.8.2",
    "svelte": "^5.39.11",
    "terser": "^5.46.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.1.4",
    "vite-plugin-dts": "^3.7.3",
    "vitest": "^1.3.1",
    "vue": "^3.5.22",
    "wrangler": "^4.39.0",
    "zone.js": "^0.15.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
