{
  "name": "@qredex/agent",
  "version": "1.0.0",
  "description": "Lightweight browser agent for Qredex intent capture and locking",
  "private": false,
  "type": "module",
  "main": "./dist/qredex-agent.iife.js",
  "module": "./dist/qredex-agent.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/qredex-agent.es.js",
      "require": "./dist/qredex-agent.iife.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.iife.config.ts && node scripts/copy-iife-min.js production",
    "build:dev": "tsc && vite build --mode development && vite build --config vite.iife.config.ts --mode development && node scripts/copy-iife-min.js development",
    "build:stage": "tsc && vite build --mode staging && vite build --config vite.iife.config.ts --mode staging && node scripts/copy-iife-min.js staging",
    "example": "node scripts/run-example.mjs",
    "example:serve": "npm run build:dev && node scripts/static-server.mjs",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.html\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"examples/**/*.html\"",
    "test": "vitest run",
    "test:browser": "npm run build:dev && playwright test",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:bun": "bun test",
    "link": "bun link",
    "unlink": "bun unlink"
  },
  "keywords": [
    "qredex",
    "browser-agent",
    "intent",
    "ecommerce"
  ],
  "author": "Qredex",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^1.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "happy-dom": "^13.3.8",
    "prettier": "^3.2.5",
    "terser": "^5.46.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.1.4",
    "vite-plugin-dts": "^3.7.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
